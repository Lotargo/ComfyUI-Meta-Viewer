{
  "schema_version": "1",
  "id": "core-two-stage",
  "name": "Core two-stage refine",
  "version": "1.0.0",
  "category": "advanced",
  "media_type": "image",
  "workflow": "workflow.json",
  "description": "An explicit two-pipeline template for base generation and checkpoint refinement.",
  "required_nodes": ["CheckpointLoaderSimple", "CLIPTextEncode", "EmptyLatentImage", "KSampler", "VAEDecode", "SaveImage"],
  "resource_slots": {
    "base_checkpoint": {"label": "Base checkpoint", "accepts": ["checkpoint"], "required": true, "binding": {"kind": "node_input", "node_id": "1", "input": "ckpt_name"}},
    "refiner_checkpoint": {"label": "Refiner checkpoint", "accepts": ["checkpoint"], "required": true, "binding": {"kind": "node_input", "node_id": "2", "input": "ckpt_name"}},
    "base_loras": {"label": "Base LoRA networks", "accepts": ["lora", "locon", "dora"], "required": false, "multiple": true, "binding": {"kind": "lora_chain", "source_node_id": "1"}}
  },
  "fields": [
    {"id": "positive_prompt", "label": "Positive prompt", "kind": "textarea", "section": "Prompt", "default": "Editorial cinematic portrait, sophisticated lighting, tactile detail", "required": true, "bindings": [{"node_id": "3", "input": "text"}, {"node_id": "7", "input": "text"}]},
    {"id": "negative_prompt", "label": "What to avoid", "kind": "textarea", "section": "Prompt", "default": "low quality, artifacts, oversmoothed", "advanced": true, "bindings": [{"node_id": "4", "input": "text"}, {"node_id": "8", "input": "text"}]},
    {"id": "width", "label": "Width", "kind": "number", "section": "Image", "default": 1024, "minimum": 64, "maximum": 8192, "step": 8, "advanced": true, "bindings": [{"node_id": "5", "input": "width"}]},
    {"id": "height", "label": "Height", "kind": "number", "section": "Image", "default": 1024, "minimum": 64, "maximum": 8192, "step": 8, "advanced": true, "bindings": [{"node_id": "5", "input": "height"}]},
    {"id": "seed", "label": "Seed", "kind": "seed", "section": "Sampling", "default": -1, "minimum": -1, "maximum": 1125899906842624, "step": 1, "advanced": true, "bindings": [{"node_id": "6", "input": "seed"}, {"node_id": "9", "input": "seed"}]},
    {"id": "base_steps", "label": "Base quality steps", "kind": "number", "section": "Sampling", "default": 24, "minimum": 1, "maximum": 200, "step": 1, "advanced": true, "bindings": [{"node_id": "6", "input": "steps"}]},
    {"id": "refiner_steps", "label": "Refiner quality steps", "kind": "number", "section": "Sampling", "default": 12, "minimum": 1, "maximum": 200, "step": 1, "advanced": true, "bindings": [{"node_id": "9", "input": "steps"}]},
    {"id": "cfg", "label": "Prompt strength (CFG)", "kind": "number", "section": "Sampling", "default": 6.5, "minimum": 0, "maximum": 30, "step": 0.1, "advanced": true, "bindings": [{"node_id": "6", "input": "cfg"}, {"node_id": "9", "input": "cfg"}]},
    {"id": "sampler", "label": "Sampling method", "kind": "select", "section": "Sampling", "default": "dpmpp_2m", "advanced": true, "options": [{"value": "euler", "label": "Euler"}, {"value": "dpmpp_2m", "label": "DPM++ 2M"}, {"value": "dpmpp_2m_sde", "label": "DPM++ 2M SDE"}], "bindings": [{"node_id": "6", "input": "sampler_name"}, {"node_id": "9", "input": "sampler_name"}]},
    {"id": "scheduler", "label": "Sampling schedule", "kind": "select", "section": "Sampling", "default": "karras", "advanced": true, "options": [{"value": "normal", "label": "Normal"}, {"value": "karras", "label": "Karras"}, {"value": "exponential", "label": "Exponential"}], "bindings": [{"node_id": "6", "input": "scheduler"}, {"node_id": "9", "input": "scheduler"}]},
    {"id": "refiner_denoise", "label": "Refiner denoise", "kind": "number", "section": "Sampling", "default": 0.28, "minimum": 0, "maximum": 1, "step": 0.01, "advanced": true, "bindings": [{"node_id": "9", "input": "denoise"}]},
    {"id": "filename_prefix", "label": "Filename prefix", "kind": "text", "section": "Output", "default": "CMV/TwoStage", "advanced": true, "bindings": [{"node_id": "11", "input": "filename_prefix"}]}
  ],
  "output_nodes": ["11"]
}
